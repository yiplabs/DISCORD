# ============================================
# TommyYipXYZ's Hub Bot — Environment Variables
# ============================================

# 1. Go to https://discord.com/developers/applications
# 2. Click "New Application" → name it "TommyYipXYZ Bot"
# 3. Go to "Bot" tab → click "Reset Token" → copy it here
# 4. ENABLE ALL 3 PRIVILEGED INTENTS (Presence, Server Members, Message Content)
DISCORD_TOKEN=your_bot_token_here

# 5. Go to "OAuth2" tab → copy the "Client ID"
CLIENT_ID=1485242134746628166

# Your YouTube Channel ID
# HOW TO FIND IT:
#   1. Go to https://www.youtube.com/@TOMMYYIPXYZ
#   2. Right-click → View Page Source
#   3. Ctrl+F search for "channelId"
#   4. Copy the UC... string (24 characters starting with UC)
# OR go to youtube.com/account_advanced while logged in
YOUTUBE_CHANNEL_ID=your_UC_channel_id_here
